{
  "name": "forge",
  "private": true,
  "version": "0.1.0",
  "description": "Starter genérico: ideia → app no ar por pipeline autônoma (profile-driven)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @forge/waifu-chat",
    "dev:quiz": "npm run dev -w @forge/anime-quiz",
    "build": "npm run build -w @forge/waifu-chat",
    "build:quiz": "npm run build -w @forge/anime-quiz",
    "build:all": "npm run build -w @forge/waifu-chat ; npm run build -w @forge/anime-quiz",
    "lint": "npm run lint -w @forge/waifu-chat",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "node --test maestro/test/*.test.mjs",
    "maestro": "node maestro/server.mjs",
    "forge": "node maestro/forge.mjs",
    "maestro:open": "powershell -ExecutionPolicy Bypass -File scripts/start-maestro.ps1"
  },
  "engines": {
    "node": ">=20"
  }
}
