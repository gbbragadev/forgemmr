# Produto (cérebro do app) — NÃO é key do coding agent.
# Docs Z.AI: https://docs.z.ai/guides/overview/quick-start

# Provider: zai (default) | openrouter
PRODUCT_AI_PROVIDER=zai

# --- Z.AI / GLM (preferido) ---
ZAI_API_KEY=
# Z_AI_API_KEY=
# GLM_API_KEY=

# Modelos Z.AI (pricing: https://docs.z.ai/guides/overview/pricing)
# glm-4.5-flash  = FREE — default (chat viral, responde content limpo)
# glm-4.7-flash  = FREE (mais “reasoning”; pode esvaziar content se max_tokens baixo)
# glm-4.5-air    = barato pago
# glm-4.7        = qualidade média
# glm-5.2        = mais forte (caro)
ZAI_MODEL=glm-4.5-flash

# --- OpenRouter (fallback opcional) ---
# PRODUCT_AI_PROVIDER=openrouter
OPEN_ROUTER_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=WaifuChat

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# anime-quiz (apps/anime-quiz): free path é 100% estático — NÃO precisa de key de AI.
# Dev: npm run dev:quiz → http://localhost:3000 (evite :3001 se Docker ocupar)

