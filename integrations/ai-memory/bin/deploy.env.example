# Homelab-specific deploy configuration.
#
# Copy this file to `bin/deploy.env` and fill in your values. The real
# `bin/deploy.env` is gitignored — never commit it.

# SSH target (user@host or just host if you've set it up in ~/.ssh/config).
SERVER="me@homelab.example.com"

# Absolute path on the homelab where docker-compose.yml + .env.production live.
# The deploy script runs `docker compose pull/down/up` inside this dir.
DEPLOY_DIR="/var/opt/docker/utils/ai-memory"

# Image tag to build + push + pull. Make sure the Docker host can pull
# from wherever you push to (Docker Hub, GHCR, your own registry).
# Default: the official published image. Change to your own fork if
# you're building from source.
IMAGE="akitaonrails/ai-memory:latest"

# Optional: override the container name if your docker-compose.yml
# uses something other than the default `ai-memory`.
# CONTAINER_NAME="ai-memory"
