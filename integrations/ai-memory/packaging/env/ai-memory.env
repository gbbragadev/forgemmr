# Environment file read by the system ai-memory.service.
#
# Keep one KEY=value assignment per line. Do not quote values unless the value
# itself contains quotes; systemd EnvironmentFile is not a shell script.
#
# Common choices:
# AI_MEMORY_AUTH_TOKEN=<generated with: ai-memory generate-auth-token>
# AI_MEMORY_ALLOWED_HOSTS=localhost,127.0.0.1,::1
# AI_MEMORY_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# AI_MEMORY_EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...
